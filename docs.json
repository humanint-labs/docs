{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Capisum",
  "description": "Customer API documentation for Capisum integrators.",
  "theme": "luma",
  "logo": {
    "light": "/logo/icon-light.svg",
    "dark": "/logo/icon-dark.svg",
    "href": "/"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#14532D",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "Capisum Docs",
      "twitter:card": "summary_large_image",
      "og:type": "website"
    }
  },
  "search": {
    "prompt": "Search docs..."
  },
  "api": {
    "openapi": "openapi.json",
    "mdx": {
      "server": "https://api.capisum.com",
      "auth": {
        "method": "bearer"
      }
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": ["bash", "javascript", "python"],
      "defaults": "required",
      "autogenerate": true
    },
    "playground": {
      "display": "interactive"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Authentication",
        "icon": "key",
        "pages": [
          "index",
          "quickstart",
          "authentication"
        ]
      },
      {
        "group": "Guides",
        "icon": "book-open",
        "pages": [
          "guides/providers",
          "guides/provider-network",
          "guides/payouts",
          "guides/account-verification",
          "guides/idempotency",
          "guides/pagination",
          "guides/errors"
        ]
      },
      {
        "group": "Providers",
        "openapi": "openapi.json",
        "pages": [
          "GET /v1/providers",
          "GET /v1/providers/{slug}/status",
          "GET /v1/providers/{slug}/balance",
          "POST /v1/verify/account"
        ]
      },
      {
        "group": "Transactions",
        "openapi": "openapi.json",
        "pages": [
          "POST /v1/transactions/payout",
          "GET /v1/transactions",
          "GET /v1/transactions/ref/{reference}",
          "GET /v1/transactions/{id}",
          "POST /v1/transactions/{id}/verify"
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://app.capisum.com"
    }
  },
  "contextual": {
    "options": ["assistant"]
  },
  "footer": {
    "links": [
      {
        "header": "Capisum",
        "items": [
          {
            "label": "Website",
            "href": "https://capisum.com"
          },
          {
            "label": "Products",
            "href": "https://capisum.com/products"
          },
          {
            "label": "Providers",
            "href": "https://capisum.com/providers"
          },
          {
            "label": "Sandbox",
            "href": "https://capisum.com/sandbox"
          },
          {
            "label": "Contact",
            "href": "https://capisum.com/contact"
          }
        ]
      },
      {
        "header": "Developers",
        "items": [
          {
            "label": "Dashboard",
            "href": "https://app.capisum.com"
          },
          {
            "label": "Support",
            "href": "mailto:support@capisum.com"
          }
        ]
      }
    ],
    "socials": {}
  }
}
