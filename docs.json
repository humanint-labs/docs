{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Capisum",
  "description": "Capisum documentation for integrating and managing multiple payment providers through one unified API.",
  "theme": "luma",
  "logo": {
    "light": "/logo/icon-light.svg",
    "dark": "/logo/icon-dark.svg",
    "href": "/"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#D4A0FF",
    "light": "#FAFAFA",
    "dark": "#15803D"
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "Capisum Docs",
      "twitter:card": "summary_large_image",
      "og:type": "website"
    }
  },
  "search": {
    "prompt": "Search docs..."
  },
  "api": {
    "openapi": "openapi.json",
    "mdx": {
      "server": "https://api.capisum.com",
      "auth": {
        "method": "bearer"
      }
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": ["bash", "javascript", "python"],
      "defaults": "required",
      "autogenerate": true
    },
    "playground": {
      "display": "interactive"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get started",
            "icon": "rocket",
            "pages": [
              "index",
              "quickstart",
              "guides/sandbox",
              "authentication"
            ]
          },
          {
            "group": "Payouts",
            "icon": "money-bill-transfer",
            "pages": [
              "guides/payouts",
              "guides/webhooks",
              "guides/account-verification"
            ]
          },
          {
            "group": "Providers",
            "icon": "plug",
            "pages": [
              "guides/providers",
              "guides/provider-network"
            ]
          },
          {
            "group": "API essentials",
            "icon": "list",
            "pages": [
              "guides/idempotency",
              "guides/pagination",
              "guides/errors"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "icon": "square-terminal",
        "openapi": "openapi.json",
        "groups": [
          {
            "group": "Providers",
            "pages": [
              "GET /v1/providers",
              "GET /v1/providers/{slug}/status",
              "GET /v1/providers/{slug}/balance",
              "POST /v1/verify/account"
            ]
          },
          {
            "group": "Transactions",
            "pages": [
              "POST /v1/transactions/payout",
              "GET /v1/transactions",
              "GET /v1/transactions/ref/{reference}",
              "GET /v1/transactions/{id}",
              "POST /v1/transactions/{id}/verify"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://app.capisum.com"
    }
  },
  "contextual": {
    "options": ["assistant"]
  },
  "footer": {
    "links": [
      {
        "header": "Capisum",
        "items": [
          {
            "label": "Website",
            "href": "https://capisum.com"
          },
          {
            "label": "Products",
            "href": "https://capisum.com/products"
          },
          {
            "label": "Contact",
            "href": "https://capisum.com/contact"
          }
        ]
      },
      {
        "header": "Developers",
        "items": [
          {
            "label": "Dashboard",
            "href": "https://app.capisum.com"
          },
          {
            "label": "Sandbox",
            "href": "/guides/sandbox"
          },
          {
            "label": "Support",
            "href": "mailto:support@capisum.com"
          }
        ]
      }
    ],
    "socials": {}
  },
  "appearance": {
    "strict": false
  },
  "fonts": {
    "family": "Geist"
  },
  "background": {
    "color": {
      "dark": "#0A0A0A"
    }
  }
}
